# ============================================================================
# Conversielek.nl — Lokale dev-configuratie
# ============================================================================
# Kopieer naar .env.local en pas aan. .env.local wordt niet gecommit.
#
# Vraag een Anthropic API-key aan op https://console.anthropic.com/

# ---- Mode ------------------------------------------------------------------

# Demo-modus: 'true' = mock-audit zonder API-call (geen key nodig).
# 'false' = echte AI-call via /api/audit naar Anthropic.
NEXT_PUBLIC_DEMO_MODE=true

# ---- Anthropic (alleen nodig als DEMO_MODE=false) --------------------------

# Server-only (geen NEXT_PUBLIC_ prefix → blijft op de server).
ANTHROPIC_API_KEY=

# ---- API-hardening ---------------------------------------------------------

# Comma-separated whitelist van toegestane origins voor /api/audit.
# Leeg = dev-default (localhost:3000 + 127.0.0.1:3000).
# Productie: zet dit op je domein, bv. https://conversielek.nl
ALLOWED_ORIGINS=

# Maximum audits per IP per minuut (in-memory rate limit; voor productie
# op Vercel later vervangen door Upstash Redis).
RATE_LIMIT_PER_MIN=10
